{
  "name": "protobuf-es-v1-v2-codemod",
  "version": "0.1.1",
  "description": "Codemod to migrate protobuf-es v1 to v2",
  "author": "izumin5210 <m@izum.in>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/izumin5210/protobuf-es-v1-v2-codemod.git"
  },
  "bugs": {
    "url": "https://github.com/izumin5210/protobuf-es-v1-v2-codemod/issues"
  },
  "type": "module",
  "main": "dist/bin/cli.js",
  "types": "dist/bin/cli.d.ts",
  "bin": {
    "protobuf-es-v1-v2-codemod": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "!**/__tests__/**",
    "!**/*.test.ts",
    "!**/*.test.js",
    "!**/*.test.d.ts",
    "!**/*.test.js.map",
    "!**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "check": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "changeset:version": "changeset version",
    "changeset:release": "pnpm build && changeset publish"
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "jscodeshift": "^17.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
